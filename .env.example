# =============================================================================
# Time2Change — environment configuration
#
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
#
# Variables marked "(required)" have no default and MUST be set.
# Variables marked "(optional)" fall back to the shown default.
# =============================================================================


# ── PostgreSQL ────────────────────────────────────────────────────────────────

# (required) Password for the Postgres user. Choose something strong.
POSTGRES_PASSWORD=change_me

# (optional) Postgres username. Default: time2change
POSTGRES_USER=time2change

# (optional) Postgres database name. Default: time2change
POSTGRES_DB=time2change


# ── Ingestion service ─────────────────────────────────────────────────────────

# (optional) Comma-separated list of currency codes to ingest.
#            The ingestion worker will build EUR/X and X/EUR pairs for each.
#            Default: EUR,USD,GBP,JPY,CHF,CAD,AUD
CURRENCIES=EUR,USD,GBP,JPY,CHF,CAD,AUD

# (optional) Earliest date from which historical rates are fetched.
#            ISO 8601 UTC. Default: 2024-01-01T00:00:00Z
START_DATE=2024-01-01T00:00:00Z


# ── Frontend build ────────────────────────────────────────────────────────────

# (optional) The public base URL of your deployment.
#            This is baked into the WASM binary at compile time so it must be
#            set before `docker compose build`.
#
#            With the default nginx setup, API routes are proxied from the same
#            origin — set this to your public domain in production:
#
#              API_BASE_URL=https://time2change.example.com
#
#            Default for local docker compose: http://localhost
API_BASE_URL=http://localhost


# ── Port mapping ──────────────────────────────────────────────────────────────

# (optional) Host port the frontend nginx listens on. Default: 80
PORT=80
